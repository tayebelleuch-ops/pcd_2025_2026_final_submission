erDiagram
  %% ==========================================
  %% POSTGRESQL SCHEMA (Live Ground Truth)
  %% ==========================================
  PLANT_REQUIREMENTS {
    string nom_du_plante PK
    float temp_min_opt
    float temp_max_opt
    float temp_min_abs
    float temp_max_abs
    float precipitation_min_opt
    float precipitation_max_opt
    text[] nature_des_sols
    int crop_cycle_min
    int crop_cycle_max
  }
  LOCATION {
    int id PK
    string city_name
    float latitude
    float longitude
  }
  DATA_SOURCE {
    int id PK
    string name
  }
  WEATHER_DAILY {
    bigint id PK
    int location_id FK
    int source_id FK
    timestamp date_mesure
    timestamp extraction_date
    jsonb metrics
  }
  WEATHER_HOURLY {
    bigint id PK
    int location_id FK
    int source_id FK
    timestamp date_mesure
    timestamp extraction_date
    jsonb metrics
  }

  LOCATION ||--o{ WEATHER_DAILY : has
  DATA_SOURCE ||--o{ WEATHER_DAILY : provides
  LOCATION ||--o{ WEATHER_HOURLY : has
  DATA_SOURCE ||--o{ WEATHER_HOURLY : provides

  %% ==========================================
  %% CLICKHOUSE SCHEMA (Live Ground Truth)
  %% ==========================================
  FACT_WEATHER_DAILY {
    date date_mesure PK
    datetime extraction_date
    string city_name
    float latitude PK
    float longitude PK
    float temperature_2m_mean
    float temperature_2m_max
    float temperature_2m_min
    float precipitation_sum
  }
  FACT_WEATHER_HOURLY {
    datetime date_mesure PK
    datetime extraction_date
    string city_name
    float latitude PK
    float longitude PK
    float surface_pressure
  }

  LOCATION ||--o{ FACT_WEATHER_DAILY : "matches via lat/lon"
  LOCATION ||--o{ FACT_WEATHER_HOURLY : "matches via lat/lon"
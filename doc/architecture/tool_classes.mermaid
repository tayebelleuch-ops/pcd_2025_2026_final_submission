classDiagram
  class CustomDBTools {
    %% Agronomy Tools
    +check_soil_compatibility(farmer_soil_type: str, nom_du_plante: str) str
    +get_optimal_planting_window(lat: float, lon: float, nom_du_plante: str) dict
    
    %% Intercepted Graph Tool
    +fetch_graph(clickhouse_sql: str) str
  }

  class FinalResponsePayload {
    +string text
    +list chart_data
  }

  class UserContext {
    +string farmer_soil_type
    +float current_lat
    +float current_lon
  }

  UserContext ..> CustomDBTools : "Context is injected into Agent memory"
  CustomDBTools ..> FinalResponsePayload : "fetch_graph populates chart_data buffer"